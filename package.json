{
	"name": "wordpress-developer-mcp-server",
	"description": "MCP server for WordPress Development",
	"private": true,
	"type": "module",
	"version": "2.5.2",
	"scripts": {
		"build": "esbuild src/index.ts --bundle --platform=node --target=node18 --format=esm --outfile=dist/index.js --banner:js='#!/usr/bin/env node'",
		"build:watch": "npm run build -- --watch",
		"dev:build:watch:macos": "npm run build -- --watch --outfile=$HOME/.wordpress-developer-mcp/mcp/index.js",
		"dev:build:watch:windows": "npm run build -- --watch --outfile=%USERPROFILE%\\.wordpress-developer-mcp\\mcp\\index.js",
		"inspect": "npx @modelcontextprotocol/inspector node ./dist/index.js",
		"typecheck": "tsc --noEmit",
		"format": "prettier . --write"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.29.0",
		"zod": "^4.4.2"
	},
	"devDependencies": {
		"@types/node": "^25.6.0",
		"esbuild": "^0.28.0",
		"prettier": "npm:wp-prettier@^3.0.3",
		"typescript": "^6.0.3"
	}
}
